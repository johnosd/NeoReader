# Copie este arquivo para .env e preencha somente as chaves que for usar.
# Variaveis VITE_ entram no bundle web/Android; restrinja as chaves no provedor
# por API, pacote/app e cota. Nao trate valores VITE_ como segredos de servidor.

# Speechify TTS API key - opcional. Sem ela, o app usa TTS nativo como fallback.
VITE_SPEECHIFY_API_KEY=

# ElevenLabs API key - opcional. Tambem pode ser salva nas Configuracoes do app.
VITE_ELEVENLABS_API_KEY=

# Google Books API key - opcional, recomendada para reduzir 429/quota publica.
VITE_GOOGLE_BOOKS_API_KEY=

# NYT Books API key - opcional, habilita a aba Descubra/NYT Best Sellers.
VITE_NYT_API_KEY=

# YouTube Data API v3 e salva localmente pela tela Configuracoes do app.
# Nao ha variavel VITE_ lida pelo codigo atual para essa chave.
