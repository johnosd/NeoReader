# Speechify TTS API key — obtenha em https://console.speechify.ai/
# Sem esta variável, o app usa o TTS nativo do Android como fallback.
# Copie este arquivo para .env e preencha com sua chave real.
VITE_SPEECHIFY_API_KEY=sua_chave_aqui

# Google Books API key opcional — recomendada para evitar erro 429/quota publica.
# Obtenha no Google Cloud Console e habilite Books API.
VITE_GOOGLE_BOOKS_API_KEY=sua_chave_google_books_aqui
